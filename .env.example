# Square API
SQUARE_ENVIRONMENT=sandbox
SQUARE_APP_ID=your-square-app-id
SQUARE_APP_SECRET=your-square-app-secret
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_SANDBOX_BASE_URL=https://connect.squareupsandbox.com

# Clover API
CLOVER_ENVIRONMENT=sandbox
CLOVER_APP_ID=your-clover-app-id
CLOVER_APP_SECRET=your-clover-app-secret
CLOVER_ACCESS_TOKEN=your-clover-access-token
CLOVER_MERCHANT_ID=your-clover-merchant-id

# Stripe (for checkout sessions + subscriptions)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STANDARD=price_...   # $250/mo recurring
STRIPE_PRICE_PREMIUM=price_...    # $500/mo recurring
STRIPE_PRICE_COMMAND=price_...    # $1000/mo recurring

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
