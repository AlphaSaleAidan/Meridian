# Square API
SQUARE_ENVIRONMENT=sandbox
SQUARE_APP_ID=your-square-app-id
SQUARE_APP_SECRET=your-square-app-secret
SQUARE_ACCESS_TOKEN=your-square-access-token

# Clover API
CLOVER_ENVIRONMENT=sandbox
CLOVER_APP_ID=your-clover-app-id
CLOVER_APP_SECRET=your-clover-app-secret
CLOVER_ACCESS_TOKEN=your-clover-access-token
CLOVER_MERCHANT_ID=your-clover-merchant-id

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Postal (self-hosted email)
POSTAL_HOST=http://localhost:5000
POSTAL_API_KEY=your-postal-api-key
POSTAL_FROM=Meridian <hello@meridian.tips>
POSTAL_WEBHOOK_SECRET=your-postal-webhook-secret

# Backblaze B2 — primary archive ($0.006/GB)
B2_KEY_ID=your-b2-key-id
B2_APP_KEY=your-b2-application-key
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_BUCKET_RAW=meridian-data-raw

# Cloudflare R2 — buyer delivery ($0.015/GB, $0 egress)
CF_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=meridian-marketplace

# Square — data marketplace payments (uses same Square app as POS)
SQUARE_MARKETPLACE_WEBHOOK_SECRET=your-square-marketplace-webhook-signature-key
SQUARE_LINK_BENCHMARKS=https://square.link/your-benchmarks-checkout
SQUARE_LINK_FOOT_TRAFFIC=https://square.link/your-foot-traffic-checkout
SQUARE_LINK_FULL_SUITE=https://square.link/your-full-suite-checkout
SQUARE_LINK_ARCHIVE=https://square.link/your-archive-checkout

# Anonymization
ANONYMIZATION_SALT=generate-with-openssl-rand-hex-32

# Sentry error tracking
SENTRY_DSN=
ENVIRONMENT=production

# PostHog analytics
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Stripe billing (alternative to Square billing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
