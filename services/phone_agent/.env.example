# Meridian AI Phone Agent — Environment Variables
# 100% open source — no paid API keys required

# ─── Fonoster (self-hosted SIP) ───────────────────────────
FONOSTER_API_URL=http://localhost:3000
SIP_DOMAIN=sip.yourdomain.com
SERVER_PUBLIC_IP=your.server.ip.address

# ─── SIP Trunk (only external cost — ~$0.004/min) ────────
# VoIP.ms or Telnyx for real PSTN connectivity
# Skip entirely for testing with SIP soft phones
SIP_TRUNK_HOST=voip.ms
SIP_TRUNK_USER=
SIP_TRUNK_PASSWORD=

# ─── Ollama (self-hosted LLM) ────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.3:70b
# Lighter alternatives: llama3.1:8b, qwen2.5:7b

# ─── WhisperLiveKit (self-hosted STT) ────────────────────
WHISPER_MODEL=medium
# Options: base, small, medium, large-v3
WHISPER_DEVICE=auto
# Options: auto, cuda, cpu
WHISPER_COMPUTE_TYPE=int8
# Options: int8 (CPU), float16 (GPU)

# ─── Kokoro TTS (self-hosted TTS) ────────────────────────
KOKORO_VOICE=af_bella
# Voices: af_bella, af_sarah, am_adam, am_michael
KOKORO_SPEED=1.1

# ─── Phone Agent Service ─────────────────────────────────
PHONE_AGENT_PORT=8090
PIPECAT_WS_URL=ws://localhost:8090/ws
LOG_LEVEL=INFO

# ─── Existing Meridian Services ──────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
