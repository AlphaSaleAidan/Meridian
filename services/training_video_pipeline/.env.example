# Meridian Training Video Pipeline — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# Anthropic (for DeerFlow script generation — optional, fallback works without it)
ANTHROPIC_API_KEY=

# DeerFlow workspace path
DEERFLOW_WORKSPACE=/root/Meridian/services/deerflow

# Supabase (optional — only needed if uploading videos to cloud)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# No other paid APIs needed. edge-tts and Pillow are fully free.
