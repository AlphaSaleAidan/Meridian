# Meridian Training Video Pipeline — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# Anthropic (DeerFlow LLM backend)
ANTHROPIC_API_KEY=

# Higgsfield (video generation)
HIGGSFIELD_API_KEY=
HIGGSFIELD_SOUL_ID=

# mem0 (persistent memory across pipeline runs)
MEM0_API_KEY=

# Supabase (video upload + lesson record updates)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# DeerFlow workspace path
DEERFLOW_WORKSPACE=/root/Meridian/services/deerflow
