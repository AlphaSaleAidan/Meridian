# Meridian Dashboard Environment Variables
# Copy to .env.local and fill in values

# Backend API URL (no trailing slash)
# Dev: leave empty (Vite proxy handles it)
# Prod: https://your-railway-app.up.railway.app
VITE_API_URL=

# Organization ID (from Supabase organizations table)
VITE_ORG_ID=

# Supabase (for future client-side auth)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry error tracking (optional)
VITE_SENTRY_DSN=
